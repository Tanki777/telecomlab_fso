FILE_TYPE=LIBRARY_PARTS;
PRIMITIVE 'OPV302','OPV302_Other';
  PIN
    'VCSEL_ANODE':
      PIN_NUMBER='(1)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='UNSPEC';
    'VCSEL_CATHODE':
      PIN_NUMBER='(2)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='UNSPEC';
    'NO_CONNECTION':
      PIN_NUMBER='(3)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='UNSPEC';
  END_PIN;
  BODY
    PART_NAME='OPV302';
    PHYS_DES_PREFIX='D';
    NO_LOAD_CHECK='TRUE';
    PIN_COUNT='3';
    BODY_NAME='OPV302';
    JEDEC_TYPE='OPV302';
  END_BODY;
END_PRIMITIVE;
END.
